# ============================================================
# NatuJM v3 — Variables de Entorno de PRODUCCIÓN
# Copiar estas variables al panel de Vercel (Settings → Environment Variables)
# ============================================================

# ------------------------------------
# Base de Datos (Supabase / PostgreSQL)
# Obtener desde: Supabase → Settings → Database → Connection string → URI
# IMPORTANTE: usar el modo "Transaction" (pooler) para serverless
# ------------------------------------
DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# ------------------------------------
# NextAuth
# Generar secret: openssl rand -base64 32
# ------------------------------------
NEXTAUTH_SECRET="<generado-con-openssl-rand-base64-32>"
NEXTAUTH_URL="https://www.naturajm.com"

# ------------------------------------
# Cloudinary (Panel: https://cloudinary.com/console)
# ------------------------------------
CLOUDINARY_CLOUD_NAME="tu-cloud-name"
CLOUDINARY_API_KEY="tu-api-key"
CLOUDINARY_API_SECRET="tu-api-secret"

# ------------------------------------
# PayPal — Producción (no sandbox)
# Panel: https://developer.paypal.com/dashboard
# ------------------------------------
NEXT_PUBLIC_PAYPAL_CLIENT_ID="tu-client-id-produccion"
PAYPAL_CLIENT_SECRET="tu-client-secret-produccion"

# ------------------------------------
# Stripe — Producción (claves pk_live_ y sk_live_)
# Panel: https://dashboard.stripe.com/apikeys
# ------------------------------------
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_live_..."
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# ------------------------------------
# Resend (Emails transaccionales)
# Panel: https://resend.com/api-keys
# ------------------------------------
RESEND_API_KEY="re_..."

# ------------------------------------
# WhatsApp
# ------------------------------------
NEXT_PUBLIC_WHATSAPP_NUMBER="18091234567"

# ------------------------------------
# App
# ------------------------------------
NEXT_PUBLIC_APP_URL="https://www.naturajm.com"
NODE_ENV="production"
